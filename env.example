# Hubitat hub LAN IP (e.g. 192.168.1.10)
HUBITAT_HUB_IP=

# Maker API app ID (the number in the Maker API URL)
HUBITAT_APP_ID=

# Maker API access token
HUBITAT_ACCESS_TOKEN=

# Bearer token that AI clients must send as `Authorization: Bearer <this>`
# Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=

# Optional tunables
# LOG_LEVEL=INFO
# HTTP_TIMEOUT=10
